# ==============================================================================
# Nonotion Docker Environment Variables
# ==============================================================================
# Copy this file to .env and customize for your deployment
# ==============================================================================

# JWT secret for signing authentication tokens
# REQUIRED: Generate a secure random string for production
# Example: openssl rand -hex 32
JWT_SECRET=your-secure-secret-here-change-in-production

# Admin email - the user who registers with this email becomes admin
# If not set, the first user to register becomes admin
ADMIN_EMAIL=admin@example.com

# Web server port (exposed to host)
# Default: 80
WEB_PORT=80

# CORS allowed origins (comma-separated)
# For production, set to your actual domain(s)
# Default: http://localhost,http://localhost:80
CORS_ORIGINS=http://localhost,http://localhost:80

# ==============================================================================
# Advanced Configuration (usually not needed)
# ==============================================================================

# API port (internal, only change if you have conflicts)
# PORT=3001

# API upstream for nginx proxy (only change for custom setups)
# API_UPSTREAM=api:3001

# Vite API URL (build-time, only for standalone web deployment)
# VITE_API_URL=/api
