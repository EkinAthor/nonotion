{
  "name": "nonotion",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:status": "node scripts/dev-tool.js status",
    "dev:stop": "node scripts/dev-tool.js stop",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "clean": "turbo clean && rimraf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "turbo": "^2.3.0",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "overrides": {
      "markdown-it": "^14.1.1",
      "esbuild": "^0.25.0",
      "ajv": "^8.18.0",
      "minimatch": "^10.2.1",
      "fastify": "^5.7.3",
      "@fastify/jwt": "^9.0.0"
    }
  }
}