# ==============================================================================
# Nonotion API Environment Configuration
# Copy this file to .env for local development
# ==============================================================================

# JWT secret for signing tokens - change in production!
JWT_SECRET=dev-secret-change-in-production

# Admin email - user registering with this email becomes admin
# If not set, the first registered user becomes admin
ADMIN_EMAIL=

# Require admin approval for new users (default: true)
REQUIRE_USER_APPROVAL=true

# API server port (default: 3001)
PORT=3001

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage backend: 'sqlite' (default) or 'postgres'
STORAGE_TYPE=sqlite

# Data directory for SQLite database (default: ../../data)
DATA_DIR=

# PostgreSQL connection URL (required when STORAGE_TYPE=postgres)
# DATABASE_URL=postgresql://nonotion:nonotion@localhost:5432/nonotion

# Maximum file upload size in MB (default: 10)
MAX_FILE_SIZE_MB=10

# Data directory for SQLite database and JSON files
# Can be absolute or relative path (relative to apps/api)
# Default: ../../data (project root data folder)
DATA_DIR=../../data

# Authentication modes (comma-separated): db | google | db,google (default: db)
AUTH_MODES=db

# Google OAuth Client ID (required when AUTH_MODES includes 'google')
# Get from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=

# Rate limiting (default: enabled, auto-disabled on Vercel)
# Set RATE_LIMIT_ENABLED=false to disable all rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MINUTES=1
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MINUTES=15
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_UPLOAD_WINDOW_MINUTES=1
RATE_LIMIT_IMPORT_MAX=3
RATE_LIMIT_IMPORT_WINDOW_MINUTES=1
RATE_LIMIT_SEARCH_MAX=30
RATE_LIMIT_SEARCH_WINDOW_MINUTES=1

# ------------------------------------------------------------------------------
# Real-time Collaboration (optional, requires Supabase)
# ------------------------------------------------------------------------------

# Enable real-time presence and live editing (default: false)
REALTIME_ENABLED=false

# Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase publishable API key (format: sb_publishable_...).
# Safe for frontend. Replaces the legacy anon key.
# Create in Dashboard -> Settings -> API -> API Keys.
SUPABASE_PUBLISHABLE_KEY=

# Supabase secret API key (format: sb_secret_...).
# Backend-only, NEVER expose to frontend. Replaces the legacy service_role key.
SUPABASE_SECRET_KEY=

# ES256 JWT signing key as a JWK (JSON Web Key) string, used to sign Realtime
# auth tokens. Backend-only. Generate with:
#   node apps/api/scripts/generate-jwt-signing-key.mjs
# Wrap the single-line JSON in single quotes in .env (JSON uses double quotes).
# Example: SUPABASE_JWT_PRIVATE_KEY='{"kty":"EC","crv":"P-256","x":"...","y":"...","d":"...","alg":"ES256","use":"sig"}'
SUPABASE_JWT_PRIVATE_KEY=

# Key ID (kid) shown by Supabase after importing the standby signing key.
# Dashboard -> Settings -> Auth -> JWT Signing Keys. Included in JWT header for verification.
SUPABASE_JWT_KID=
