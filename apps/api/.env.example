# JWT secret for signing tokens
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET=dev-secret-change-in-production

# Admin email - the user who registers with this email becomes admin
# If not set, the first user to register becomes admin
ADMIN_EMAIL=admin@example.com

# API server port (default: 3001)
PORT=3001

# CORS allowed origins (comma-separated)
# Example: http://localhost:5173,http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data directory for SQLite database and JSON files
# Can be absolute or relative path (relative to apps/api)
# Default: ../../data (project root data folder)
DATA_DIR=../../data

# Require admin approval for new user registrations
# Default (not set or true): new users start in pending state and need admin approval
# Set to false to auto-approve new users (they can access the app immediately)
REQUIRE_USER_APPROVAL=true
