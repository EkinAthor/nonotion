{
  "name": "@nonotion/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.pg.config.ts",
    "db:migrate:pg": "tsx src/db/migrate-pg.ts",
    "db:studio:pg": "drizzle-kit studio --config=drizzle.pg.config.ts",
    "migrate:multiuser": "tsx src/scripts/migrate-to-multiuser.ts",
    "migrate:to-postgres": "tsx src/scripts/migrate-to-postgres.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.4.0",
    "@nonotion/shared": "workspace:*",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.0.0",
    "google-auth-library": "^10.5.0",
    "papaparse": "^5.5.3",
    "pg": "^8.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.8",
    "rimraf": "^5.0.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}