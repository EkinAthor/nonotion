{
  "product": {
    "name": "Nonotion",
    "version": "0.2.0",
    "description": "Self-hosted, lightweight Notion alternative with block-based content editing"
  },
  "currentFeatures": {
    "storage": {
      "backends": ["json-sqlite", "postgres"],
      "default": "json-sqlite",
      "supabaseCompatible": true
    },
    "authentication": {
      "enabled": true,
      "method": "JWT",
      "features": ["register", "login", "password-change", "admin-reset"],
      "userApproval": true
    },
    "pages": {
      "enabled": true,
      "subPages": true,
      "database": true,
      "starring": true,
      "sharing": true,
      "permissionLevels": ["owner", "full_access", "editor", "viewer"]
    },
    "blocks": {
      "types": ["heading", "heading2", "heading3", "paragraph"],
      "formatting": true,
      "formattingFeatures": ["bold", "italic", "underline", "inline-code", "links", "text-color", "background-color"],
      "dragAndDrop": true,
      "slashCommands": true,
      "enterCreatesNewBlock": true,
      "arrowKeyNavigation": true
    },
    "database": {
      "enabled": true,
      "tableView": true,
      "propertyTypes": ["title", "text", "select", "multi_select", "date", "person", "url", "checkbox"],
      "filtering": true,
      "sorting": true
    },
    "deployment": {
      "docker": true,
      "localDev": true
    }
  },
  "technicalStack": {
    "frontend": {
      "framework": "React",
      "buildTool": "Vite",
      "language": "TypeScript",
      "stateManagement": "Zustand",
      "styling": "Tailwind CSS",
      "editor": "TipTap"
    },
    "backend": {
      "runtime": "Node.js",
      "framework": "Fastify",
      "language": "TypeScript",
      "orm": "Drizzle ORM",
      "storage": ["JSON files", "SQLite", "PostgreSQL"]
    },
    "testing": {
      "e2e": "Playwright"
    },
    "monorepo": {
      "packageManager": "pnpm",
      "orchestration": "Turborepo"
    }
  },
  "dataModels": {
    "user": {
      "id": "string (usr_xxx)",
      "email": "string",
      "name": "string",
      "passwordHash": "string",
      "role": "admin | user",
      "approved": "boolean",
      "mustChangePassword": "boolean",
      "createdAt": "ISO8601 string",
      "updatedAt": "ISO8601 string"
    },
    "page": {
      "id": "string (pg_xxx)",
      "title": "string",
      "type": "document | database",
      "ownerId": "string",
      "parentId": "string | null",
      "childIds": "string[]",
      "icon": "string | null",
      "isStarred": "boolean",
      "databaseSchema": "object | null",
      "properties": "object | null",
      "createdAt": "ISO8601 string",
      "updatedAt": "ISO8601 string",
      "version": "number"
    },
    "block": {
      "id": "string (blk_xxx)",
      "type": "heading | heading2 | heading3 | paragraph",
      "pageId": "string",
      "order": "number",
      "content": "object",
      "version": "number"
    },
    "permission": {
      "pageId": "string",
      "userId": "string",
      "level": "owner | full_access | editor | viewer",
      "grantedBy": "string",
      "grantedAt": "ISO8601 string"
    }
  },
  "apiEndpoints": {
    "auth": {
      "register": "POST /api/auth/register",
      "login": "POST /api/auth/login",
      "me": "GET /api/auth/me",
      "changePassword": "POST /api/auth/change-password"
    },
    "users": {
      "list": "GET /api/users",
      "search": "GET /api/users/search",
      "updateRole": "PATCH /api/users/:id/role",
      "approve": "PATCH /api/users/:id/approve",
      "resetPassword": "POST /api/users/:id/reset-password",
      "delete": "DELETE /api/users/:id"
    },
    "pages": {
      "list": "GET /api/pages",
      "get": "GET /api/pages/:id",
      "create": "POST /api/pages",
      "update": "PATCH /api/pages/:id",
      "delete": "DELETE /api/pages/:id"
    },
    "blocks": {
      "list": "GET /api/pages/:pageId/blocks",
      "create": "POST /api/pages/:pageId/blocks",
      "update": "PATCH /api/blocks/:id",
      "delete": "DELETE /api/blocks/:id",
      "reorder": "PATCH /api/pages/:pageId/blocks/reorder"
    },
    "shares": {
      "list": "GET /api/pages/:id/shares",
      "create": "POST /api/pages/:id/shares",
      "update": "PATCH /api/pages/:id/shares/:userId",
      "delete": "DELETE /api/pages/:id/shares/:userId"
    },
    "databases": {
      "getRows": "GET /api/databases/:id/rows",
      "updateSchema": "PATCH /api/databases/:id/schema",
      "updateRowProperties": "PATCH /api/databases/:id/rows/:rowId/properties"
    }
  },
  "futureFeatures": {
    "blocks": [
      "Bullet list",
      "Numbered list",
      "Toggle",
      "Quote",
      "Code block",
      "Rich text formatting (bold, italic, etc.) - IMPLEMENTED",
      "Block nesting"
    ],
    "collaboration": [
      "Real-time collaboration",
      "Presence indicators",
      "@ mentions"
    ],
    "integrations": [
      "Import from Notion",
      "Export functionality",
      "Plugin API"
    ],
    "authentication": [
      "Google OAuth",
      "Other OAuth providers"
    ]
  }
}
