# ==============================================================================
# Nonotion Environment Configuration
# Copy this file to .env and update the values
# ==============================================================================

# JWT secret for authentication (required in production)
JWT_SECRET=your-secret-key-change-in-production

# Admin user email - first user with this email becomes admin
# If not set, the first registered user becomes admin
ADMIN_EMAIL=

# User approval requirement
# Set to 'false' to auto-approve new user registrations
# Default: requires admin approval
REQUIRE_USER_APPROVAL=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API server port
PORT=3001

# ==============================================================================
# Storage Configuration
# ==============================================================================

# Storage backend type: 'json-sqlite' (default) or 'postgres'
STORAGE_TYPE=json-sqlite

# Data directory for JSON/SQLite storage (default: ./data)
DATA_DIR=

# PostgreSQL connection URL (required when STORAGE_TYPE=postgres)
# Standard PostgreSQL:
# DATABASE_URL=postgresql://nonotion:nonotion@localhost:5432/nonotion
#
# Supabase:
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ==============================================================================
# Docker Configuration
# ==============================================================================

# Web server port (default: 80)
WEB_PORT=80
