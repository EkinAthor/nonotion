# ==============================================================================
# Nonotion Environment Configuration
# Copy this file to .env and update the values
# ==============================================================================

# ------------------------------------------------------------------------------
# Authentication (Required)
# ------------------------------------------------------------------------------

# JWT secret for signing tokens - MUST be changed in production!
JWT_SECRET=your-secret-key-change-in-production

# Admin user email - user registering with this email becomes admin
# If not set, the first registered user becomes admin
ADMIN_EMAIL=

# Require admin approval for new user registrations
# true (default): new users need admin approval before accessing the app
# false: new users are auto-approved
REQUIRE_USER_APPROVAL=true

# ------------------------------------------------------------------------------
# Storage Configuration
# ------------------------------------------------------------------------------

# Storage backend: 'sqlite' (default) or 'postgres'
STORAGE_TYPE=sqlite

# Data directory for SQLite database (default: ./data)
# Only used when STORAGE_TYPE=sqlite
DATA_DIR=

# PostgreSQL connection URL (required when STORAGE_TYPE=postgres)
# Local:    postgresql://nonotion:nonotion@postgres:5432/nonotion
# Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# ------------------------------------------------------------------------------
# File Uploads
# ------------------------------------------------------------------------------

# Maximum file upload size in MB (default: 10)
MAX_FILE_SIZE_MB=10

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------

# API server port (default: 3001)
PORT=3001

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------

# Enable/disable rate limiting (default: true, auto-disabled on Vercel)
RATE_LIMIT_ENABLED=true

# Global: requests per window per IP (default: 100 req / 1 min)
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MINUTES=1

# Auth endpoints (login/register/google): attempts per window (default: 10 req / 15 min)
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MINUTES=15

# File upload: per window (default: 10 req / 1 min)
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_UPLOAD_WINDOW_MINUTES=1

# Import: per window (default: 3 req / 1 min)
RATE_LIMIT_IMPORT_MAX=3
RATE_LIMIT_IMPORT_WINDOW_MINUTES=1

# Search: per window (default: 30 req / 1 min)
RATE_LIMIT_SEARCH_MAX=30
RATE_LIMIT_SEARCH_WINDOW_MINUTES=1

# ------------------------------------------------------------------------------
# Real-time Collaboration (optional, requires Supabase)
# ------------------------------------------------------------------------------

# Enable real-time presence and live editing (default: false)
REALTIME_ENABLED=false

# Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase anon/public key (safe for frontend)
SUPABASE_ANON_KEY=

# Supabase service role key (backend-only, NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase JWT secret (used to sign Realtime auth tokens, backend-only)
SUPABASE_JWT_SECRET=

# ------------------------------------------------------------------------------
# Docker Configuration (only for docker-compose)
# ------------------------------------------------------------------------------

# Web server port (default: 80)
WEB_PORT=80
